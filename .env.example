PORT=3000

# SQL Server connection
DB_SERVER=BLACKHACK
DB_PORT=1433
DB_DATABASE=HONAI
DB_USER=sa
DB_PASSWORD=

# Use true for Azure SQL or encrypted SQL Server connections.
DB_ENCRYPT=false

# Use true for local/dev SQL Server with self-signed certificates.
DB_TRUST_SERVER_CERTIFICATE=true

# Optional pool tuning
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_POOL_IDLE_TIMEOUT=30000

# Backblaze B2 / S3-compatible object storage
B2_ENDPOINT=
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=
B2_PUBLIC_URL=

# WhatsApp Cloud API
WA_API_VERSION=v25.0
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
WA_TEST_TO=
WA_NOTIFICATION_TEMPLATE=hello_world
WA_NOTIFICATION_TEMPLATE_LANGUAGE=en_US
